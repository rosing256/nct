<!DOCTYPE html>
<html lang="zh-CN">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>NCT 数据后台</title>

<script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>

<style>
body{
  font-family:sans-serif;
  padding:40px;
  background:#f5f5f5;
}

.card{
  background:white;
  padding:20px;
  border-radius:16px;
  margin-bottom:20px;
  box-shadow:0 2px 8px rgba(0,0,0,0.1);
}

.card h2{
  margin-top:0;
  color:#333;
  border-bottom:2px solid #111;
  padding-bottom:10px;
}

.loading{
  text-align:center;
  padding:40px;
  font-size:18px;
  color:#666;
}

.option-row{
  display:flex;
  align-items:center;
  margin-bottom:12px;
  gap:10px;
}

.option-label{
  min-width:100px;
  font-weight:bold;
}

.option-bar-wrapper{
  flex:1;
  background:#e0e0e0;
  border-radius:999px;
  overflow:hidden;
  height:28px;
}

.option-bar{
  height:100%;
  background:linear-gradient(90deg,#667eea 0%,#764ba2 100%);
  color:white;
  display:flex;
  align-items:center;
  padding-left:10px;
  font-size:12px;
  font-weight:bold;
}

.option-count{
  min-width:90px;
  text-align:right;
}

.stat-grid{
  display:grid;
  grid-template-columns:repeat(auto-fit,minmax(200px,1fr));
  gap:15px;
}

.stat-item{
  background:#f8f9fa;
  padding:20px;
  border-radius:12px;
  text-align:center;
}

.stat-number{
  font-size:32px;
  font-weight:bold;
  color:#667eea;
}

.stat-label{
  color:#666;
  margin-top:5px;
}

.refresh-btn{
  background:#667eea;
  color:white;
  border:none;
  padding:12px 24px;
  border-radius:8px;
  font-size:16px;
  cursor:pointer;
  margin-bottom:20px;
}

.refresh-btn:hover{
  background:#764ba2;
}

.table-container{
  overflow-x:auto;
}

table{
  width:100%;
  border-collapse:collapse;
}

th,td{
  padding:12px;
  border-bottom:1px solid #eee;
  text-align:left;
}

th{
  background:#111;
  color:white;
}

@media(max-width:768px){
  body{
    padding:16px;
  }
}
</style>
</head>

<body>

<h1>📊 NCT 人格测试数据后台</h1>

<button class="refresh-btn" onclick="loadData()">🔄 刷新数据</button>

<div class="card">
  <h2>📈 总体概览</h2>
  <div id="overview"></div>
</div>

<div class="card">
  <h2>🎭 人格分布统计</h2>
  <div id="types"></div>
</div>

<div class="card">
  <h2>📝 详细测试记录</h2>
  <div class="table-container">
    <table>
      <thead id="records-thead"></thead>
      <tbody id="records-tbody"></tbody>
    </table>
  </div>
</div>

<script>

// ===== Supabase 配置 =====
const supabaseUrl = 'https://kwxhzcrzhswgrxfuyjpv.supabase.co';
const supabaseKey = 'eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6Imt3eGh6Y3J6aHN3Z3J4ZnV5anB2Iiwicm9sZSI6ImFub24iLCJpYXQiOjE3Nzk5NDA0MzksImV4cCI6MjA5NTUxNjQzOX0.XZ3yjbLOLae5oknq3WBNBPfVgmZbDOS6125nP7mjLOo';

// ===== 修复重点：正确获取 createClient =====
const { createClient } = window.supabase;

const supabaseClient = createClient(
  supabaseUrl,
  supabaseKey
);

// ===== 题目配置 =====
const QUESTIONS_CONFIG = {
  q0:'第1题',
  q1:'第2题',
  q2:'第3题',
  q3:'第4题',
  q4:'第5题',
  q5:'第6题',
  q6:'第7题',
  q7:'第8题',
  q8:'第9题',
  q9:'第10题',
  q10:'第11题',
  q11:'第12题'
};

// ===== 加载数据 =====
async function loadData(){

  document.getElementById('overview').innerHTML = `
    <div class="loading">⏳ 正在加载数据...</div>
  `;

  try {

    const { data, error } = await supabaseClient
      .from('test_results')
      .select('*')
      .order('created_at', { ascending:false });

    console.log('Supabase 数据：', data);

    if(error){
      throw error;
    }

    if(!data || data.length === 0){
      document.getElementById('overview').innerHTML = `
        <div class="loading">📭 暂无数据</div>
      `;
      return;
    }

    renderOverview(data);
    renderTypes(data);
    renderTable(data);

  } catch(err){

    console.error(err);

    document.getElementById('overview').innerHTML = `
      <div class="loading">
        ❌ 加载失败：${err.message}
      </div>
    `;
  }
}

// ===== 总体概览 =====
function renderOverview(data){

  const typeSet = new Set();

  data.forEach(item=>{
    typeSet.add(item.result_code || '未知');
  });

  document.getElementById('overview').innerHTML = `
    <div class="stat-grid">
      <div class="stat-item">
        <div class="stat-number">${data.length}</div>
        <div class="stat-label">测试总人数</div>
      </div>

      <div class="stat-item">
        <div class="stat-number">${typeSet.size}</div>
        <div class="stat-label">人格类型数量</div>
      </div>
    </div>
  `;
}

// ===== 人格统计 =====
function renderTypes(data){

  const counts = {};

  data.forEach(item=>{
    const code = item.result_code || '未知';

    if(!counts[code]){
      counts[code] = 0;
    }

    counts[code]++;
  });

  const container = document.getElementById('types');
  container.innerHTML = '';

  Object.entries(counts)
    .sort((a,b)=>b[1]-a[1])
    .forEach(([type,count])=>{

      const percent = Math.round(count / data.length * 100);

      container.innerHTML += `
        <div class="option-row">
          <div class="option-label">${type}</div>

          <div class="option-bar-wrapper">
            <div class="option-bar" style="width:${percent}%">
              ${percent}%
            </div>
          </div>

          <div class="option-count">${count}人</div>
        </div>
      `;
    });
}

// ===== 表格 =====
function renderTable(data){

  const thead = document.getElementById('records-thead');
  const tbody = document.getElementById('records-tbody');

  // ===== 获取所有题目 =====
  const allQuestions = new Set();

  data.forEach(item=>{
    const answers = item.answers || {};

    Object.keys(answers).forEach(q=>{
      allQuestions.add(q);
    });
  });

  const sortedQuestions = Array.from(allQuestions).sort();

  // ===== 表头 =====
  let headerHTML = `
    <tr>
      <th>序号</th>
      <th>时间</th>
      <th>人格类型</th>
  `;

  sortedQuestions.forEach(q=>{
    headerHTML += `<th>${QUESTIONS_CONFIG[q] || q}</th>`;
  });

  headerHTML += `</tr>`;

  thead.innerHTML = headerHTML;

  // ===== 内容 =====
  tbody.innerHTML = '';

  data.forEach((item,index)=>{

    const answers = item.answers || {};

    const time = item.created_at
      ? new Date(item.created_at).toLocaleString('zh-CN')
      : '未知';

    let row = `
      <tr>
        <td>${index + 1}</td>
        <td>${time}</td>
        <td><strong>${item.result_code || '未知'}</strong></td>
    `;

    sortedQuestions.forEach(q=>{

      let value = answers[q];

      if(Array.isArray(value)){
        value = value.join(', ');
      }

      if(value === undefined || value === null || value === ''){
        value = '-';
      }

      row += `<td>${value}</td>`;
    });

    row += `</tr>`;

    tbody.innerHTML += row;
  });
}

// ===== 自动加载 =====
window.addEventListener('load', ()=>{
  loadData();
});

</script>

</body>
</html>
